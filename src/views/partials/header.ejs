<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Блог</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;1,8..60,300&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="logo">Блог<span class="logo-dot">.</span></a>
      <nav class="nav" id="mainNav">
        <a href="/posts" class="nav-link">Записи</a>
        <% if (currentUser) { %>
          <a href="/posts/new" class="nav-link nav-cta">+ Написати</a>
          <a href="/profile" class="nav-avatar-link">
            <% if (currentUser.avatar) { %>
              <img src="<%= currentUser.avatar %>" alt="<%= currentUser.username %>" class="avatar avatar-sm">
            <% } else { %>
              <div class="avatar avatar-sm avatar-placeholder"><%= currentUser.username[0].toUpperCase() %></div>
            <% } %>
            <span class="nav-username"><%= currentUser.username %></span>
          </a>
          <form action="/auth/logout" method="POST" class="inline-form">
            <button type="submit" class="btn-ghost-sm">Вийти</button>
          </form>
        <% } else { %>
          <a href="/auth/login" class="nav-link">Вхід</a>
          <a href="/auth/register" class="nav-link nav-cta">Реєстрація</a>
        <% } %>
      </nav>
      <button class="menu-toggle" id="menuToggle" aria-label="Меню">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <% if (success && success.length > 0) { %>
    <div class="flash flash-success" id="flash"><%= success[0] %></div>
  <% } %>
  <% if (error && error.length > 0) { %>
    <div class="flash flash-error" id="flash"><%= error[0] %></div>
  <% } %>
