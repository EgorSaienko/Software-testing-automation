<%- include('../partials/header') %>

<div class="auth-page">
  <div class="auth-card">
    <h1 class="auth-title">Вхід</h1>
    <p class="auth-subtitle">Раді бачити вас знову!</p>

    <% if (errors && errors.length > 0) { %>
      <div class="error-list">
        <% errors.forEach(e => { %><div class="error-item"><%= e.msg %></div><% }) %>
      </div>
    <% } %>

    <form action="/auth/login" method="POST">
      <div class="form-group">
        <label class="form-label" for="email">Email</label>
        <input class="form-control" type="email" id="email" name="email"
               value="<%= typeof old !== 'undefined' && old.email ? old.email : '' %>"
               placeholder="you@example.com" required autocomplete="email">
      </div>
      <div class="form-group">
        <label class="form-label" for="password">Пароль</label>
        <input class="form-control" type="password" id="password" name="password"
               placeholder="Ваш пароль" required autocomplete="current-password">
        <div class="form-hint"><a href="/auth/forgot-password">Забули пароль?</a></div>
      </div>
      <button type="submit" class="btn btn-dark btn-full">Увійти</button>
    </form>

    <hr class="auth-divider">
    <p class="auth-footer">
      Ще немає акаунту? <a href="/auth/register">Зареєструватись</a>
    </p>
  </div>
</div>

<%- include('../partials/footer') %>
