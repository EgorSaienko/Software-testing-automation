<%- include('../partials/header') %>

<div class="auth-page">
  <div class="auth-card">
    <h1 class="auth-title">Змінити пароль</h1>
    <p class="auth-subtitle">Введіть поточний пароль і новий</p>

    <% if (errors && errors.length > 0) { %>
      <div class="error-list">
        <% errors.forEach(e => { %><div class="error-item"><%= e.msg %></div><% }) %>
      </div>
    <% } %>

    <form action="/auth/change-password" method="POST">
      <div class="form-group">
        <label class="form-label" for="currentPassword">Поточний пароль</label>
        <input class="form-control" type="password" id="currentPassword" name="currentPassword" required>
      </div>
      <div class="form-group">
        <label class="form-label" for="newPassword">Новий пароль</label>
        <input class="form-control" type="password" id="newPassword" name="newPassword"
               placeholder="Мінімум 6 символів" required>
      </div>
      <div class="form-group">
        <label class="form-label" for="confirmPassword">Підтвердити новий пароль</label>
        <input class="form-control" type="password" id="confirmPassword" name="confirmPassword" required>
      </div>
      <div class="form-actions">
        <button type="submit" class="btn btn-dark">Змінити пароль</button>
        <a href="/profile" class="btn btn-outline">Скасувати</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
