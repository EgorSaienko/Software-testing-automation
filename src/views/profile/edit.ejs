<%- include('../partials/header') %>

<div class="form-page">
  <h1 class="form-page-title">Редагувати профіль</h1>
  <p class="form-page-subtitle">Оновіть ваш публічний профіль</p>

  <% if (errors && errors.length > 0) { %>
    <div class="error-list">
      <% errors.forEach(e => { %><div class="error-item"><%= e.msg %></div><% }) %>
    </div>
  <% } %>

  <div class="form-card">
    <form action="/profile/edit" method="POST" enctype="multipart/form-data">
      <div class="form-group" style="display:flex;align-items:center;gap:1.5rem;margin-bottom:1.75rem;">
        <% if (user.avatar) { %>
          <img src="<%= user.avatar %>" alt="<%= user.username %>" class="avatar avatar-lg">
        <% } else { %>
          <div class="avatar avatar-lg avatar-placeholder"><%= user.username[0].toUpperCase() %></div>
        <% } %>
        <div style="flex:1;">
          <label class="form-label">Аватарка</label>
          <div class="file-input-wrapper">
            <label class="file-input-label">
              📷 <span class="file-label-text">Обрати нове фото</span>
              <input type="file" name="avatar" accept="image/*">
            </label>
          </div>
          <div class="form-hint">Рекомендовано: квадратне зображення, макс. 2MB</div>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label" for="username">Ім'я користувача *</label>
        <input class="form-control" type="text" id="username" name="username"
               value="<%= user.username %>" required>
      </div>

      <div class="form-group">
        <label class="form-label" for="bio">Про себе</label>
        <textarea class="form-control" id="bio" name="bio" rows="4"
                  placeholder="Розкажіть трохи про себе..."><%= user.bio || '' %></textarea>
        <div class="form-hint">До 500 символів</div>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Зберегти</button>
        <a href="/profile" class="btn btn-outline">Скасувати</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
